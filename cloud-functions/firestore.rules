rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function userExists() {
      return isSignedIn() && exists(currentUserPath());
    }

    function role() {
      return userExists() ? get(currentUserPath()).data.role : null;
    }

    function isAdmin() {
      return role() in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return role() == 'superadmin';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
      );

      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (
          isAdmin() &&
          resource.data.role == 'student' &&
          request.resource.data.role == resource.data.role
        ) ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role
        )
      );

      allow delete: if isSuperAdmin();
    }

    match /exams/{examId} {
      allow read: if isSignedIn() && (
        isAdmin() || resource.data.status == 'published'
      );

      allow create, update, delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/exams/$(resource.data.examId)).data.status == 'published'
      );

      allow create, update, delete: if isAdmin();
    }

    match /examSessions/{sessionId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (resource != null && resource.data.studentUid == request.auth.uid) ||
        sessionId.matches('.*_' + request.auth.uid)
      );

      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.studentUid == request.auth.uid
      );

      allow update: if isSignedIn() && (
        isAdmin() || resource.data.studentUid == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
